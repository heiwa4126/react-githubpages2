{
	"name": "react-githubpages2",
	"private": true,
	"version": "1.0.20",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"format": "biome format --write . && dprint fmt  && textlint --fix \"**/*.md\"",
		"check": "biome check --write . && dprint check",
		"lint": "biome lint .",
		"actionlint": "actionlint .github/**/*.yml",
		"preview": "vite preview",
		"bp": "tsc && vite build && vite preview"
	},
	"dependencies": {
		"react": "~19.2.4",
		"react-dom": "~19.2.4",
		"react-router": "~7.13.1"
	},
	"devDependencies": {
		"@types/node": "^25.3.5",
		"@types/react": "~19.2.14",
		"@types/react-dom": "~19.2.3",
		"@vitejs/plugin-react-swc": "^4.2.3",
		"typescript": "^5.9.3",
		"vite": "~7.3.1"
	}
}
