{
	"name": "react-githubpages2",
	"private": true,
	"version": "1.0.20",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"format": "biome format --write . && dprint fmt  && textlint --fix \"**/*.md\"",
		"check": "biome check --write . && dprint check",
		"lint": "biome lint .",
		"actionlint": "actionlint .github/**/*.yml",
		"preview": "vite preview",
		"bp": "tsc && vite build && vite preview"
	},
	"dependencies": {
		"react": "~19.2.7",
		"react-dom": "~19.2.7",
		"react-router": "~8.1.0"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"@types/react": "~19.2.17",
		"@types/react-dom": "~19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "~8.1.2"
	}
}
